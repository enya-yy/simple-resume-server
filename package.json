{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "fetch-fonts": "node scripts/fetch-export-fonts.mjs",
    "build": "pnpm fetch-fonts && nest build && cp src/worker/render/resume-preview.css dist/worker/render/ && cp -R worker/src/render/fonts dist/worker/render/",
    "predev": "pnpm -C packages/sqlite-pg build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "node -r ./scripts/load-sqlite-env.cjs scripts/sqlite-migrate.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm --dir packages/sqlite-pg typecheck && pnpm --dir packages/sqlite-pg build && pnpm typecheck && pnpm build && pnpm --dir worker typecheck && pnpm --dir worker build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/throttler": "6.5.0",
    "@simple-resume/sqlite-pg": "file:./packages/sqlite-pg",
    "argon2": "0.44.0",
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "1.4.7",
    "csrf": "^3.1.0",
    "dotenv": "^17.3.1",
    "express-session": "^1.19.0",
    "helmet": "8.1.0",
    "markdown-it": "^14.1.1",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^4.4.0",
    "puppeteer": "^24.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.2.0",
    "sanitize-html": "^2.17.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.13",
    "@types/express-session": "^1.18.2",
    "@types/jest": "29.5.1",
    "@types/multer": "^1.4.12",
    "@types/pdf-parse": "^1.1.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "18.16.12",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "29.5.0",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "29.1.0",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "puppeteer"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core"
    ]
  }
}