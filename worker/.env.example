# 必须与 API 的 SQLITE_DATABASE_PATH 指向同一文件（相对路径相对仓库根）。
# 未设置时：development/test -> local-db/simple-resume.db；production -> /home/ubuntu/projects/simple-resume/db/simple-resume.db
# SQLITE_DATABASE_PATH=local-db/simple-resume.db

# 与 API 相同：Worker 上传 PDF 后由 API 签发预签名 GET
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=simple-resume-exports
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true

# 对话辅助：与 API 一致。未设置 LLM_PROVIDER 时，若存在 DEEPSEEK_API_KEY 则优先 DeepSeek，否则回退 DASHSCOPE_API_KEY。

# DeepSeek V4（OpenAI 兼容，默认 deepseek-v4-flash）
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云百炼 — 对话辅助（DashScope OpenAI 兼容 Chat Completions）
# 控制台 API-KEY：https://bailian.console.aliyun.com/
# LLM_PROVIDER=dashscope
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-turbo
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
