# 必须与 apps/api/.env 中 SQLITE_DATABASE_PATH 指向同一文件（相对路径相对仓库根）
SQLITE_DATABASE_PATH=data/simple-resume.db

# 与 API 相同：Worker 上传 PDF 后由 API 签发预签名 GET
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=simple-resume-exports
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true

# 阿里云百炼 — 对话辅助（DashScope OpenAI 兼容 Chat Completions）
# 控制台 API-KEY：https://bailian.console.aliyun.com/
# DASHSCOPE_API_KEY=
