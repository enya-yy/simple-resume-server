{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json && cp src/render/resume-preview.css dist/render/ && cp -R src/render/fonts dist/render/",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@simple-resume/sqlite-pg": "file:../packages/sqlite-pg",
    "dotenv": "^17.3.1",
    "markdown-it": "^14.1.1",
    "puppeteer": "^24.6.0",
    "sanitize-html": "^2.17.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.4",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.23.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "puppeteer"
    ]
  }
}
