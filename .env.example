NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000

# API 内置 worker 也使用该 SQLite 文件；相对路径相对**仓库根**（非 cwd）。
# 未设置时：development/test -> local-db/simple-resume.db；production -> /home/ubuntu/projects/simple-resume/db/simple-resume.db
# SQLITE_DATABASE_PATH=local-db/simple-resume.db

SESSION_SECRET=replace-with-long-random-secret-min-32-chars
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 测试机仅 HTTP 且登录报 CSRF_INVALID 时可设为 false（生产 HTTPS 建议 auto 或省略）
# SESSION_COOKIE_SECURE=false
# TRUST_PROXY=true

# 运营聚合接口 `/ops/metrics`（仅服务端；勿写入前端构建）
# OPS_METRICS_TOKEN=

# S3 兼容存储（导出 PDF 预签名下载；本地可用 MinIO）
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=simple-resume-exports
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true
# S3_DOWNLOAD_URL_TTL_SECONDS=900
# EXPORT_PRESIGN_STUB=true

# LLM Provider — DeepSeek V4（OpenAI 兼容，默认 deepseek-v4-flash 性价比高）
# LLM_PROVIDER=stub
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_INTENT_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 仍可使用阿里云百炼：
# LLM_PROVIDER=dashscope
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-turbo
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 开启后在 PM2 日志与浏览器控制台输出 LLM 调用链路（SSE event: debug）
# LLM_DEBUG=true

# 内置 worker 超时（毫秒）
# POLISH_JOB_TIMEOUT_MS=120000
# CHAT_ASSIST_JOB_TIMEOUT_MS=120000
