NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000

# API 内置 worker 也使用该 SQLite 文件；相对路径相对**仓库根**（非 cwd）。
# 未设置时：development/test -> local-db/simple-resume.db；production -> /home/ubuntu/projects/simple-resume/db/simple-resume.db
# SQLITE_DATABASE_PATH=local-db/simple-resume.db

SESSION_SECRET=replace-with-long-random-secret-min-32-chars
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 运营聚合接口 `/ops/metrics`（仅服务端；勿写入前端构建）
# OPS_METRICS_TOKEN=

# S3 兼容存储（导出 PDF 预签名下载；本地可用 MinIO）
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=simple-resume-exports
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true
# S3_DOWNLOAD_URL_TTL_SECONDS=900
# EXPORT_PRESIGN_STUB=true

# LLM Provider
# LLM_PROVIDER=stub
# LLM_PROVIDER=dashscope
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-turbo
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 内置 worker 超时（毫秒）
# POLISH_JOB_TIMEOUT_MS=120000
# CHAT_ASSIST_JOB_TIMEOUT_MS=120000
